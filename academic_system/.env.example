# Backend Environment Configuration

# Application Environment
ENVIRONMENT=development

# MongoDB Connection
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=academic_system

# JWT Configuration
# IMPORTANT: Change this to a strong random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-secret-key-in-production-use-secrets-token-urlsafe-64

# API Configuration
API_PREFIX=/api/v1
APP_NAME=Academic Management System
APP_VERSION=1.0.0

# JWT Expiration (minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_REFRESH_ENABLED=true

# CORS Origins (supports both formats)
# Comma-separated: http://localhost:3000,http://localhost:8000
# JSON array: ["http://localhost:3000", "http://localhost:8000"]
# For production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads
ALLOWED_FILE_EXTENSIONS=.pdf,.doc,.docx,.ppt,.pptx,.zip,.rar

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Email Configuration (Gmail SMTP)
EMAIL_ENABLED=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@nitsri.ac.in
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=NIT Srinagar Academic Portal <your-email@nitsri.ac.in>
EMAIL_FROM_NAME=NIT Srinagar Academic Portal
